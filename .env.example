# ============================================================
# VARIABLES DE ENTORNO — FINCO ARCOS
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env real a GitHub.
# ============================================================

# URL de tu proyecto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave pública anon (Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui
